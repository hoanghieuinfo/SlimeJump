<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Fullscreen game theme – no ActionBar, no title bar -->
    <style name="Theme.Slime" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/slime_blue_primary</item>
        <item name="colorPrimaryVariant">@color/slime_blue_dark</item>
        <item name="colorOnPrimary">@color/slime_text</item>
        <item name="colorSecondary">@color/slime_accent</item>
        <item name="colorSecondaryVariant">@color/slime_accent</item>
        <item name="colorOnSecondary">@color/slime_text</item>
        <!-- Make status bar transparent (fullscreen set programmatically) -->
        <item name="android:statusBarColor">#00000000</item>
        <item name="android:windowBackground">@color/slime_blue_dark</item>
        
        <!-- Global Font -->
        <item name="fontFamily">@font/pixel_font</item>
        <item name="android:fontFamily">@font/pixel_font</item>
        
        <!-- Material Components Font Overrides -->
        <item name="textAppearanceHeadline1">@style/SlimeTextAppearance</item>
        <item name="textAppearanceHeadline2">@style/SlimeTextAppearance</item>
        <item name="textAppearanceHeadline3">@style/SlimeTextAppearance</item>
        <item name="textAppearanceHeadline4">@style/SlimeTextAppearance</item>
        <item name="textAppearanceHeadline5">@style/SlimeTextAppearance</item>
        <item name="textAppearanceHeadline6">@style/SlimeTextAppearance</item>
        <item name="textAppearanceSubtitle1">@style/SlimeTextAppearance</item>
        <item name="textAppearanceSubtitle2">@style/SlimeTextAppearance</item>
        <item name="textAppearanceBody1">@style/SlimeTextAppearance</item>
        <item name="textAppearanceBody2">@style/SlimeTextAppearance</item>
        <item name="textAppearanceCaption">@style/SlimeTextAppearance</item>
        <item name="textAppearanceButton">@style/SlimeTextAppearance</item>
        <item name="textAppearanceOverline">@style/SlimeTextAppearance</item>
    </style>

    <style name="SlimeTextAppearance" parent="TextAppearance.MaterialComponents.Body1">
        <item name="fontFamily">@font/pixel_font</item>
        <item name="android:fontFamily">@font/pixel_font</item>
    </style>
</resources>